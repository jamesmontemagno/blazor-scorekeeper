@inherits LayoutComponentBase
@inject NavigationManager Nav
@inject IThemeService ThemeService
@inject IGameService GameService
@inject ILocalStorageService LocalStorage
@inject IJSRuntime JS
@implements IDisposable

<div class="maui-layout">
    <header class="maui-header">
        <div class="maui-header-inner">
            <NavLink class="maui-brand" href="/" Match="NavLinkMatch.All">
                <i class="bi bi-trophy-fill trophy-icon me-2"></i>
                <span class="brand-text">My Score Keeper</span>
            </NavLink>
            <div class="maui-header-actions">
                <NavLink class="btn-header-settings" href="/settings" aria-label="Settings">
                    <i class="bi bi-gear-fill" aria-hidden="true"></i>
                </NavLink>
            </div>
        </div>
    </header>

    <main class="maui-content">
        <div class="container py-3">
            @Body
        </div>
    </main>

    <nav class="maui-bottom-nav" aria-label="Main navigation">
        <NavLink class="maui-nav-item" href="/" Match="NavLinkMatch.All">
            <i class="bi bi-house-fill"></i>
            <span>Home</span>
        </NavLink>
        <NavLink class="maui-nav-item" href="/setup">
            <i class="bi bi-plus-circle-fill"></i>
            <span>Setup</span>
        </NavLink>
        @if (_hasActiveGame)
        {
            <NavLink class="maui-nav-item" href="/play">
                <i class="bi bi-play-fill"></i>
                <span>Play</span>
            </NavLink>
        }
        <NavLink class="maui-nav-item" href="/history">
            <i class="bi bi-clock-history"></i>
            <span>History</span>
        </NavLink>
    </nav>
</div>

<div id="blazor-error-ui">
    An unhandled error has occurred.
    <a href="" class="reload">Reload</a>
    <a class="dismiss">🗙</a>
</div>

@code {
    private bool _hasActiveGame = false;
    private bool _locationChangedSubscribed = false;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            var theme = await ThemeService.GetThemeAsync();
            try { await JS.InvokeVoidAsync("setAppTheme", theme); } catch { /* JS may not be ready on first render */ }

            // Quick check from localStorage, then verify with backing store
            _hasActiveGame = await LocalStorage.GetHasActiveGameAsync();
            StateHasChanged();

            var actual = await GameService.HasActiveGameAsync();
            if (actual != _hasActiveGame)
            {
                _hasActiveGame = actual;
                StateHasChanged();
            }

            Nav.LocationChanged += OnLocationChanged;
            _locationChangedSubscribed = true;
        }
    }

    private async void OnLocationChanged(object? sender, Microsoft.AspNetCore.Components.Routing.LocationChangedEventArgs e)
    {
        try
        {
            var hasActive = await GameService.HasActiveGameAsync();
            if (hasActive != _hasActiveGame)
            {
                _hasActiveGame = hasActive;
                await InvokeAsync(StateHasChanged);
            }
        }
        catch
        {
            // Ignore errors during navigation-triggered refresh
        }
    }

    public void Dispose()
    {
        if (_locationChangedSubscribed)
        {
            Nav.LocationChanged -= OnLocationChanged;
        }
    }
}
