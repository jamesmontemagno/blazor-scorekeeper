@inherits LayoutComponentBase
@inject NavigationManager Nav
@inject IThemeService ThemeService
@inject IJSRuntime JS
@inject IGameService GameService
@inject ILocalStorageService LocalStorage
@implements IDisposable

<div class="status-bar-safe-area"></div>

<div class="app-container">
    <nav class="navbar navbar-expand-md sticky-top app-navbar">
        <div class="container">
            <NavLink class="navbar-brand" href="/" Match="NavLinkMatch.All">
                <i class="bi bi-trophy-fill trophy-icon me-2" aria-hidden="true"></i>
                <span class="brand-text">My Score Keeper</span>
            </NavLink>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#mainNav" aria-controls="mainNav" aria-expanded="false" aria-label="Toggle navigation">
                <span class="navbar-toggler-icon" aria-hidden="true"></span>
            </button>
            <div class="collapse navbar-collapse" id="mainNav">
                <ul class="navbar-nav ms-auto">
                    <li class="nav-item">
                        <NavLink class="nav-link" href="/" Match="NavLinkMatch.All">
                            <i class="bi bi-house-fill me-1" aria-hidden="true"></i>
                            Home
                        </NavLink>
                    </li>
                    <li class="nav-item">
                        <NavLink class="nav-link" href="/setup">
                            <i class="bi bi-plus-circle-fill me-1" aria-hidden="true"></i>
                            Setup
                        </NavLink>
                    </li>
                    @if (_hasActiveGame)
                    {
                        <li class="nav-item">
                            <NavLink class="nav-link" href="/play">
                                <i class="bi bi-play-fill me-1" aria-hidden="true"></i>
                                Play
                            </NavLink>
                        </li>
                    }
                    <li class="nav-item">
                        <NavLink class="nav-link" href="/history">
                            <i class="bi bi-clock-history me-1" aria-hidden="true"></i>
                            History
                        </NavLink>
                    </li>
                    <li class="nav-item theme-switcher ms-md-2 d-flex align-items-center gap-1">
                        <button class="btn-theme-toggle @(_currentTheme == "system" ? "active" : "")" @onclick='() => ChangeThemeAsync("system")' aria-label="Switch to system theme" title="System">
                            <i class="bi bi-circle-half" aria-hidden="true"></i>
                        </button>
                        <button class="btn-theme-toggle @(_currentTheme == "light" ? "active" : "")" @onclick='() => ChangeThemeAsync("light")' aria-label="Switch to light theme" title="Light">
                            <i class="bi bi-sun-fill" aria-hidden="true"></i>
                        </button>
                        <button class="btn-theme-toggle @(_currentTheme == "dark" ? "active" : "")" @onclick='() => ChangeThemeAsync("dark")' aria-label="Switch to dark theme" title="Dark">
                            <i class="bi bi-moon-stars-fill" aria-hidden="true"></i>
                        </button>
                    </li>
                </ul>
            </div>
        </div>
    </nav>

    <main class="flex-grow-1">
        <div class="container py-4">
            @Body
        </div>
    </main>

    <div id="blazor-error-ui">
        An unhandled error has occurred.
        <a href="" class="reload">Reload</a>
        <button type="button" class="dismiss" aria-label="Dismiss error">🗙</button>
    </div>
</div>

@code {
    private string _currentTheme = "system";
    private bool _hasActiveGame = false;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            _currentTheme = await ThemeService.GetThemeAsync();
            await ThemeService.ApplyThemeAsync(_currentTheme);

            // Quick check from localStorage, then verify with backing store
            _hasActiveGame = await LocalStorage.GetHasActiveGameAsync();
            StateHasChanged();

            var actual = await GameService.HasActiveGameAsync();
            if (actual != _hasActiveGame)
            {
                _hasActiveGame = actual;
                StateHasChanged();
            }

            Nav.LocationChanged += OnLocationChanged;
        }
    }

    private async void OnLocationChanged(object? sender, Microsoft.AspNetCore.Components.Routing.LocationChangedEventArgs e)
    {
        var hasActive = await GameService.HasActiveGameAsync();
        if (hasActive != _hasActiveGame)
        {
            _hasActiveGame = hasActive;
            await InvokeAsync(StateHasChanged);
        }
    }

    public void Dispose()
    {
        Nav.LocationChanged -= OnLocationChanged;
    }

    private async Task ChangeThemeAsync(string theme)
    {
        _currentTheme = theme;
        await ThemeService.SetThemeAsync(theme);
        try { await JS.InvokeVoidAsync("myMenu.closeNav"); } catch { /* ignore JS interop errors */ }
        StateHasChanged();
    }
}
